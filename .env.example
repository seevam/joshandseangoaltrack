# Neon Postgres — get both from Neon dashboard → Connect → Connection strings
# Use the "Pooled connection" URL for DATABASE_URL (required for serverless)
# Use the "Direct connection" URL for DIRECT_URL (required for Prisma migrations)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Clerk — from Clerk dashboard → API Keys
CLERK_SECRET_KEY=sk_live_...

# OpenAI — moves off the frontend, lives here instead
OPENAI_API_KEY=sk-...
